{
  "permissions": {
    "allow": [
      "Read(/Users/rdn/GitHub/**)",
      "Glob(/Users/rdn/GitHub/**)",
      "Grep(/Users/rdn/GitHub/**)",
      "Bash(semble:*)"
    ],
    "deny": [
      "Bash(brew *)"
    ],
    "defaultMode": "default",
    "additionalDirectories": [
      "/Users/rdn/GitHub"
    ]
  },
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true,
    "understand-anything@understand-anything": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    },
    "understand-anything": {
      "source": {
        "source": "github",
        "repo": "Egonex-AI/Understand-Anything"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "theme": "dark-ansi",
  "hooks": {
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "osascript -e 'display notification \"Hey look!\" with title \"Claude Code\"'"
          }
        ]
      }
    ]
  }
}
