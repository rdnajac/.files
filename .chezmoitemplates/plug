{{- $a := splitn "/" 2 .repo -}}
{{- $user := $a._0 -}}
{{- $repo := $a._1 -}}
{{- $dir := "chezmoiexternal" -}}
{{- if eq $user "tpope" }}
  {{- $dir = $user -}}
{{- end }}
{{ printf "%s/pack/%s/start/%s" .vimdir $dir $repo }}:
  type: git-repo
  url: https://github.com/{{ .repo }}.git
  refreshPeriod: 168h
