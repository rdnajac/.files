{{- $a := splitn "/" 4 . -}}
{{- $user := $a._0 -}}
{{- $repo := $a._1 -}}
{{- $dir  := $a._2 -}}
{{- $file := $a._3 -}}
chezmoiexternal/start/_/{{ $dir }}/{{ $file }}:
  type: file
  url: https://raw.githubusercontent.com/{{ $user }}/{{ $repo }}/refs/heads/master/{{ $dir }}/{{ $file }}
  refreshPeriod: 168h
