# .zshrc

# use fish without overriding the default shell
# skip if: non-interactive, in nvim, or already launched fish
if [[ -o interactive && -z "$FISH_VERSION" && -z "$NVIM" && -z "$FROM_FISH" ]]; then
  export FROM_FISH=1
  exec /opt/homebrew/bin/fish -l
fi

setopt interactivecomments # makes `#` behave like a comment character in interactive shells

[ -f "$HOME"/.bash_aliases ] && . "$HOME"/.bash_aliases

CONFDIR=${ZDOTDIR:-$HOME/.config/zsh}
# Load additional zsh configs
if [ -d "$CONFDIR" ]; then
	# `(N)` is a zsh glob qualifier
	# bash uses `shopt -s nullglob`
	for f in "$CONFDIR"/*.zsh(N); do
		. "$f"
	done
fi

# Section: History {{{
setopt APPEND_HISTORY
setopt INC_APPEND_HISTORY SHARE_HISTORY
setopt HIST_IGNORE_ALL_DUPS
setopt HIST_REDUCE_BLANKS

# see `/private/etc/zshrc` for defaults
# export HISTFILE="${ZDOTDIR:-$HOME}/.zsh_history"
# export HISTSIZE=10000
# export SAVEHIST=10000

# Don't pollute $HOME with history files
alias wget='wget --no-hsts'
export LESSHISTFILE=-
# }}}

# Section: Completion {{{
FPATH=$(brew --prefix)/share/zsh-completions:$FPATH
autoload -Uz compinit && compinit                     # initialize zsh's completion system
# autoload -Uz bashcompinit && bashcompinit             # enable bash completion scripts

export ZSH_CACHE_DIR="$HOME/.cache/zsh"
mkdir -p "$ZSH_CACHE_DIR"
zstyle ':completion:*' cache-path "$ZSH_CACHE_DIR"

zstyle ':completion:*:rsync:*' remote-access yes # rsync completion over ssh
zstyle ':completion:*:rsync:*' tag-order hosts remote-directories files
# }}}

# Section: Executables {{{
# override macOS tools with GNU versions if available
# if the names are the same, rely on the `$PATH` order
# alias awk="${HOMEBREW_PREFIX}/bin/gawk"
# alias ctags="${HOMEBREW_PREFIX}/bin/ctags"

eval "$(chezmoi completion zsh)"
eval "$(thefuck --alias)"
eval "$(zoxide init zsh)"
# }}}

# >>> mamba initialize >>>
# !! Contents within this block are managed by 'micromamba shell init' !!
export MAMBA_EXE='/Users/rdn/.local/bin/micromamba';
export MAMBA_ROOT_PREFIX='/Users/rdn/.cache/micromamba';
__mamba_setup="$("$MAMBA_EXE" shell hook --shell zsh --root-prefix "$MAMBA_ROOT_PREFIX" 2> /dev/null)"
if [ $? -eq 0 ]; then
	eval "$__mamba_setup"
else
	alias micromamba="$MAMBA_EXE"  # Fallback on help from micromamba activate
fi
unset __mamba_setup
# <<< mamba initialize <<<

