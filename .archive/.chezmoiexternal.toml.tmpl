{{- if .work }}
[".vim/"]
type = "git-repo"
url = "https://github.com/rdnajac/.vim.git"
refreshPeriod = "0s"


[".local/bin/fzf"]
type = "archive-file"
url = {{ gitHubLatestReleaseAssetURL "junegunn/fzf" (printf "fzf-*-%s_%s.tar.gz" .chezmoi.os .chezmoi.arch) | quote }}
path = "fzf"
executable = true
refreshPeriod = "168h"
{{- end }}
