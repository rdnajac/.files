# ~/.local/share/chezmoi/.chezmoi.toml.tmpl

# Use your actual dotfiles repo location
sourceDir = "{{ .chezmoi.sourceDir }}"
destinationDir = "{{ .chezmoi.destDir }}"

progress = true
verbose = true

[git]
  autoAdd = true
  autoCommit = true
  autoPush = false

[cd]
  command = '$(brew --prefix)/bin/git status'

[add]
  apply = true

[edit]
  apply = true

[update]
  apply = true
