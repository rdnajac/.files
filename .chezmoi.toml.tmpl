# ~/.local/share/chezmoi/.chezmoi.toml.tmpl

# Use your actual dotfiles repo location
sourceDir = "{{ .chezmoi.sourceDir }}"
destinationDir = "{{ .chezmoi.destDir }}"

[git]
  autoAdd = true
  autoCommit = true
  autoPush = false

[update]
  apply = true

[edit]
  apply = true

[add]
  apply = true
